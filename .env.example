# EZRA LMS - Railway Deployment Config
# Copy this to .env on Railway and fill in the real values

# SQLite Configuration
DB_TYPE=sqlite
DB_PATH=./ezralms.db

# Firebase Configuration (if using Firestore sync)
FIREBASE_CREDENTIALS_PATH=firebase_credentials.json
FIRESTORE_PROJECT_ID=threebody-933be

# Sync Configuration
SYNC_MODE=incremental
LOG_LEVEL=INFO

# Finance Auth — REQUIRED on Railway!
FINANCE_USERNAME=Imel
FINANCE_PASSWORD=YourSecurePasswordHere
